      "source": [
        "# Day 1 - Data Ingestion Check\n",
        "Use this notebook to inspect all raw CSV datasets.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from pathlib import Path\n",
        "import pandas as pd\n",
        "raw_dir = Path('../data/raw')\n",
        "for path in sorted(raw_dir.glob('*.csv')):\n",
        "    df = pd.read_csv(path)\n",
        "    print(path.name, df.shape)\n",
        "    display(df.head())\n"
      ]
    }
  ],
